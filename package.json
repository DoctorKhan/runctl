{
  "name": "@zendero/runctl",
  "version": "0.1.10",
  "description": "Picks a free port, runs your dev server in the background, and keeps PID + port state in .run/ so projects don't collide.",
  "author": "DoctorKhan",
  "homepage": "https://github.com/DoctorKhan/runctl#readme",
  "bugs": "https://github.com/DoctorKhan/runctl/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/DoctorKhan/runctl.git"
  },
  "license": "MIT",
  "keywords": [
    "runctl",
    "dev",
    "dev-server",
    "ports",
    "pid",
    "vercel",
    "dotenv",
    "vite",
    "next"
  ],
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "runctl": "bin/runctl"
  },
  "files": [
    "bin",
    "lib",
    "scripts",
    "examples",
    "docs",
    "README.md"
  ],
  "scripts": {
    "run": "bash ./run.sh",
    "test": "bash ./tests/run-all.sh",
    "doctor": "bash ./run.sh doctor",
    "release-check": "bash ./run.sh release-check",
    "promote": "bash ./run.sh promote",
    "release": "bash ./run.sh release latest",
    "env:expand": "node ./scripts/expand-env-manifest.mjs",
    "link-global": "pnpm link --global",
    "prepublishOnly": "node -e \"assert(process.env.npm_config_dry_run || process.env.PUBLISH_OK, 'Set PUBLISH_OK=1 to publish')\""
  }
}
