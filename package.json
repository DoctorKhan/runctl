{
  "name": "runctl",
  "version": "0.1.0",
  "description": "Runctl — .run/ + ~/.run port/PID helpers, JS dev wiring (Node ≥18), env manifest expander",
  "private": true,
  "license": "MIT",
  "keywords": ["runctl", "dev", "ports", "pid", "vercel", "dotenv"],
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "runctl": "bin/runctl"
  },
  "files": [
    "bin",
    "lib",
    "scripts",
    "examples",
    "docs",
    "README.md"
  ],
  "scripts": {
    "run": "bash ./run.sh",
    "expand-env": "node ./scripts/expand-env-manifest.mjs",
    "link-global": "pnpm link --global"
  }
}
