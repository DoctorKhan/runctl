#!/usr/bin/env bash
# Optional: only if you want a shell entrypoint instead of package.json scripts alone.
# Prerequisite: pnpm add -D runctl   (Node >= 18 everywhere)

set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT"

if [[ -z "${RUN_LIB:-}" ]]; then
  _rp="${RUNCTL_PACKAGE:-runctl}"
  RUN_LIB="$(
    cd "$ROOT" && RUNCTL_PACKAGE="$_rp" node -e "
      const p = require('path');
      const n = process.env.RUNCTL_PACKAGE;
      console.log(p.join(p.dirname(require.resolve(n + '/package.json')), 'lib', 'run-lib.sh'));
    "
  )" || {
    echo "run.sh: add runctl — pnpm add -D ${_rp}" >&2
    exit 1
  }
fi
[[ -f "$RUN_LIB" ]] || {
  echo "run.sh: RUN_LIB missing: $RUN_LIB" >&2
  exit 1
}
# shellcheck source=/dev/null
source "$RUN_LIB"
run_project_init "$ROOT"

usage() {
  cat <<'EOF'
Usage: ./run.sh <command>

  dev [name] [auto|PORT] [-- extra args for npm run dev]
  stop              Stop daemons + clear ~/.run port claims for this repo
  status            Local .run state + ports.env
  install           pnpm install

Examples:
  ./run.sh dev
  ./run.sh dev web auto -- --turbo
EOF
}

cmd="${1:-dev}"
shift || true

case "$cmd" in
  dev)
    run_with_lock run_start_package_dev "$@"
    ;;
  stop)
    run_stop_all
    ;;
  status)
    run_local_status
    ;;
  install)
    if command -v pnpm >/dev/null 2>&1; then
      (cd "$ROOT" && pnpm install)
    elif command -v npm >/dev/null 2>&1; then
      (cd "$ROOT" && npm install)
    else
      echo "Install pnpm or npm" >&2
      exit 1
    fi
    ;;
  help | -h | --help)
    usage
    ;;
  *)
    usage
    exit 1
    ;;
esac
