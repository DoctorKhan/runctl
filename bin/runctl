#!/usr/bin/env bash
# Runctl CLI — installed via pnpm/npm (devDependency .bin or global).
set -euo pipefail
RUNCTL_PKG_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")/.." && pwd)"
# Load optional repo .env / npm token (consumer project: set RUNCTL_PROJECT_ROOT or run from repo root).
# shellcheck source=../lib/repo-env.sh
source "$RUNCTL_PKG_ROOT/lib/repo-env.sh"
runctl_load_repo_env "${RUNCTL_PROJECT_ROOT:-$PWD}"


# Volta resolves pnpm from the *current* project's packageManager for `pnpm -v`, but
# `pnpm add -g` uses the default global pnpm (often older). Run pnpm as this package
# defines it: Corepack reads packageManager from $RUNCTL_PKG_ROOT/package.json (no
# duplicated version in shell). If Corepack is missing, fall back to npm exec with
# the same field, then plain pnpm on PATH.
_runctl_read_pnpm_version_from_package_json() {
  node -e '
    const fs = require("fs");
    const p = JSON.parse(fs.readFileSync(process.argv[1], "utf8"));
    const pm = p.packageManager || "";
    const m = /^pnpm@([0-9]+(?:\.[0-9]+){0,2})/.exec(pm);
    process.stdout.write(m ? m[1] : "");
  ' "$RUNCTL_PKG_ROOT/package.json" 2>/dev/null || true
}

# After a successful pnpm global update: short tip (global pnpm vs project pin).
_runctl_print_pnpm_version_fixup_hint() {
  local ver
  ver="$(_runctl_read_pnpm_version_from_package_json)"
  [[ -n "$ver" ]] || ver="X.Y.Z"
  cat >&2 <<EOF

${_d}┌${_r} ${_g}runctl${_r} ${_b}tip${_r} ${_d}· global pnpm can differ from your repo's packageManager pin.${_r}
${_d}│${_r}  ${_c}volta install pnpm@${ver}${_r}  ${_d}·${_r}  ${_c}corepack prepare pnpm@${ver} --activate${_r}
${_d}│${_r}  ${_c}RUNCTL_PNPM_VERSION=${ver} runctl update git${_r}  ${_d}·${_r}  ${_c}runctl update --pm npm${_r}
${_d}└${_r} ${_d}hide:${_r} ${_c}RUNCTL_UPDATE_SKIP_PNPM_HINT=1${_r}
EOF
}

_runctl_maybe_print_pnpm_update_hint() {
  local pm="$1"
  [[ "$pm" == "pnpm" ]] || return 0
  [[ -z "${RUNCTL_UPDATE_SKIP_PNPM_HINT:-}" ]] || return 0
  [[ -z "${CI:-}" ]] || return 0
  _runctl_print_pnpm_version_fixup_hint
}

_runctl_pnpm_exec() {
  if command -v corepack >/dev/null 2>&1; then
    if (cd "$RUNCTL_PKG_ROOT" && corepack pnpm "$@"); then
      return 0
    fi
    echo "runctl update: warning: corepack pnpm failed; trying npm exec / PATH pnpm" >&2
  fi
  local ver="${RUNCTL_PNPM_VERSION:-}"
  if [[ -z "$ver" ]]; then
    ver="$(_runctl_read_pnpm_version_from_package_json)"
  fi
  if [[ -n "$ver" ]] && command -v npm >/dev/null 2>&1; then
    if npm exec -y "pnpm@${ver}" -- "$@"; then
      return 0
    fi
    echo "runctl update: warning: npm exec pnpm@${ver} failed; falling back to pnpm on PATH" >&2
  fi
  command pnpm "$@"
}

_b="" _d="" _r="" _c="" _y="" _g=""
if [[ -t 1 ]]; then
  _b=$'\033[1m' _d=$'\033[2m' _r=$'\033[0m'
  _c=$'\033[36m' _y=$'\033[33m' _g=$'\033[32m'
fi

# Semver from this package's package.json (for --version and update banners).
_runctl_pkg_version() {
  local ver="?"
  if command -v node >/dev/null 2>&1; then
    ver="$(
      node -e 'const fs=require("fs"); console.log(JSON.parse(fs.readFileSync(process.argv[1],"utf8")).version);' \
        "$RUNCTL_PKG_ROOT/package.json" 2>/dev/null || echo "?"
    )"
  fi
  printf '%s' "$ver"
}


usage() {
  cat <<EOF
${_b}runctl${_r} — dev-server orchestrator & port manager

${_y}Usage:${_r}  runctl <command> [options]

${_y}Commands${_r}
  ${_c}start${_r} | ${_c}dev${_r} [dir] [--script name] [--open]  Start dev server ${_d}(alias: dev = start; ${_c}--open${_r} = browser after start)${_r}
  ${_c}open${_r}  [dir]                   Open running dev server in browser
  ${_c}stop${_r}  [dir]                   Stop daemons & release ports
  ${_c}status${_r} [dir]                  Show running state
  ${_c}ps${_r}                            List running programs with ports/projects
  ${_c}reconcile${_r} [dir]               Sync ${_d}.run/pids/*.pid${_r} + port registry from listener on ${_c}PORT${_r} in ${_d}.run/ports.env${_r}
  ${_c}stray kill${_r} [dir] [--dry-run]  Kill dev PIDs under this project not in a live ${_d}.run/pids${_r} tree ${_d}(cwd match; see help)${_r}
  ${_c}logs${_r} [dir] [service]         Tail .run/logs/<service>.log ${_d}(default: ${_c}RUNCTL_SERVICE${_r} or package name, else web)${_r}
  ${_c}ports${_r}                         List user-wide port registry (~/.run)
  ${_c}ports gc${_r}                      Clean up stale port claims
  ${_c}env expand${_r} <manifest> [opts]  Generate .env.local from manifest
  ${_c}doctor${_r}                        Check Node, tooling, and project basics
  ${_c}run-sh${_r} [--print|--write] [opts]   Emit example ${_d}run.sh${_r} ${_d}(see runctl run-sh --help)${_r}
  ${_c}update${_r} [npm|git|auto] [opts]  Update global runctl ${_d}(default: auto; see runctl update --help)${_r}
  ${_c}install${_r} [args]               Install dependencies ${_d}(pnpm preferred; npm fallback when PM=pnpm)${_r}
  ${_c}run${_r} <script> [args]          ${_d}package manager run (PM env, default pnpm)${_r}
  ${_c}exec${_r} [args]                  ${_d}package manager exec${_r}
  ${_c}test${_r} [args]                  ${_d}package manager test${_r}

${_y}Options${_r}
  ${_c}--script${_r} <name>               Package script to run ${_d}(default: dev)${_r}
  ${_c}--open${_r}                        After a successful start, open the app URL ${_d}(same as ${_c}runctl open${_r})${_r}
  ${_c}RUNCTL_PROJECT_ROOT${_r}           Repo root for .env + install/run/test ${_d}(default: cwd)${_r}
  ${_c}RUNCTL_EXTERNAL_ADOPT${_r}        Before ${_c}start${_r}: ${_d}auto${_r} | ${_d}on${_r} | ${_d}off${_r} — reuse an existing dev listener ${_d}(default ${_c}auto${_r}: path contains ${_d}.../Projects/...${_r} or repo is under ${_c}RUNCTL_PROJECTS_ROOT${_r})${_r}
  ${_c}RUNCTL_PROJECTS_ROOT${_r}         Optional root dir; with ${_c}auto${_r} adopt, limits reuse to repos under this path${_r}
  ${_c}version${_r} | ${_c}--version${_r} | ${_c}-v${_r}     Print version and package install path
  ${_c}--help${_r}, ${_c}-h${_r}                     Show this help

${_d}Quick start — add to package.json:
  "dev": "runctl start --script dev:server",
  "dev:server": "next dev",
  "dev:stop": "runctl stop"${_r}
EOF
}

_resolve_proj() {
  if [[ $# -ge 1 && -d "$1" ]]; then
    (cd "$1" && pwd)
  else
    pwd
  fi
}

cmd_start() {
  local proj script="" args=() open_after=0
  proj="$(pwd)"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --script) script="${2:-}"; shift 2 ;;
      --open) open_after=1; shift ;;
      --) shift; args+=("$@"); break ;;
      -h | --help) usage; exit 0 ;;
      -*)
        echo "runctl start: unknown flag: $1" >&2
        exit 1
        ;;
      *)
        if [[ -d "$1" ]]; then
          proj="$(cd "$1" && pwd)"
          shift
        else
          args+=("$1")
          shift
        fi
        ;;
    esac
  done

  [[ -n "$script" ]] && export RUNCTL_PM_RUN_SCRIPT="$script"

  # shellcheck source=../lib/run-lib.sh
  source "$RUNCTL_PKG_ROOT/lib/run-lib.sh"
  run_project_init "$proj"
  if ! run_with_lock run_start_package_dev "${args[@]+"${args[@]}"}"; then
    return 1
  fi
  if [[ "$open_after" -eq 1 ]]; then
    cmd_open "$proj"
  fi
}

cmd_open() {
  local proj
  proj="$(_resolve_proj "$@")"
  # shellcheck source=../lib/run-lib.sh
  source "$RUNCTL_PKG_ROOT/lib/run-lib.sh"
  run_project_init "$proj"
  local ports_env="$proj/.run/ports.env"
  if [[ ! -f "$ports_env" ]]; then
    echo "runctl open: no running server found (.run/ports.env missing)" >&2
    echo "Start one first: runctl start" >&2
    exit 1
  fi
  if ! run_local_has_live_service; then
    echo "runctl open: no running server found (saved port is stale)" >&2
    echo "Start one first: runctl start" >&2
    exit 1
  fi
  local port="" host=""
  while IFS= read -r line; do
    case "$line" in
      PORT=*) port="${line#PORT=}" ;;
      HOST=*) host="${line#HOST=}" ;;
    esac
  done <"$ports_env"
  if [[ -z "$port" ]]; then
    echo "runctl open: PORT not found in $ports_env" >&2
    exit 1
  fi
  # Prefer 127.0.0.1 over "localhost" (IPv6 vs IPv4 mismatch on macOS)
  [[ -z "$host" || "$host" == "0.0.0.0" ]] && host="127.0.0.1"
  local url="http://${host}:${port}"
  echo "runctl open: opening ${url}"
  if command -v open >/dev/null 2>&1; then
    open "$url"
  elif command -v xdg-open >/dev/null 2>&1; then
    xdg-open "$url"
  elif command -v wslview >/dev/null 2>&1; then
    wslview "$url"
  else
    echo "runctl open: no browser opener found (tried open, xdg-open, wslview)" >&2
    echo "Visit: $url" >&2
    exit 1
  fi
}

cmd_stop() {
  local proj
  proj="$(_resolve_proj "$@")"
  # shellcheck source=../lib/run-lib.sh
  source "$RUNCTL_PKG_ROOT/lib/run-lib.sh"
  run_project_init "$proj"
  run_stop_all
  echo "runctl stop: stopped local services and released claimed ports for $proj"
}

cmd_status() {
  local proj
  proj="$(_resolve_proj "$@")"
  # shellcheck source=../lib/run-lib.sh
  source "$RUNCTL_PKG_ROOT/lib/run-lib.sh"
  run_project_init "$proj"
  run_local_status
}

cmd_ports() {
  # shellcheck source=../lib/run-lib.sh
  source "$RUNCTL_PKG_ROOT/lib/run-lib.sh"
  local sub="${1:-list}"
  case "$sub" in
    list | "") run_global_list_ports ;;
    gc) run_global_gc ;;
    *)
      echo "runctl ports: unknown subcommand: $sub (try: ports, ports gc)" >&2
      exit 1
      ;;
  esac
}

cmd_ps() {
  # shellcheck source=../lib/run-lib.sh
  source "$RUNCTL_PKG_ROOT/lib/run-lib.sh"
  run_global_list_running
  local stale="${RUN_LAST_STALE_COUNT:-0}"
  if [[ "$stale" =~ ^[0-9]+$ ]] && (( stale > 0 )); then
    echo ""
    echo "runctl ps: found $stale stale registry entr$( (( stale == 1 )) && echo "y" || echo "ies" ); cleaning..."
    (run_global_gc >/dev/null 2>&1) &
    local gc_pid=$!
    wait "$gc_pid" || true
    echo "runctl ps: refreshed"
    echo ""
    run_global_list_running
  fi
}

cmd_stray_kill_usage() {
  cat <<EOF
${_b}runctl stray kill${_r} — remove orphan dev processes for a repo

${_y}Usage:${_r}  runctl stray kill [dir] [--dry-run]

${_y}Description${_r}
  Finds processes whose ${_b}cwd${_r} is this project (or a subdir other than
  ${_d}node_modules${_r}) and whose command looks like a dev runtime (${_d}node, bun, pnpm, …${_r}),
  then kills any PID that is ${_b}not${_r} in a live ${_d}.run/pids/*.pid${_r} tree
  (${_d}recorded PID + ancestors + descendants via ${_c}ps${_r} / ${_c}pgrep -P${_r}).

  ${_c}--dry-run${_r} lists PIDs that would be sent ${_c}SIGTERM${_r} without killing.

${_y}See also:${_r}  ${_c}runctl stop${_r}  ${_d}(graceful stop via saved pids)${_r}  ·  ${_c}runctl reconcile${_r}
EOF
}

cmd_stray() {
  local sub="${1:-}"
  shift || true
  case "$sub" in
    -h | --help)
      cmd_stray_kill_usage
      exit 0
      ;;
    kill)
      local dry=0 proj=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --dry-run) dry=1; shift ;;
          -h | --help)
            cmd_stray_kill_usage
            exit 0
            ;;
          -*)
            echo "runctl stray kill: unknown option: $1" >&2
            exit 1
            ;;
          *)
            if [[ -d "$1" ]]; then
              proj="$(cd "$1" && pwd)" || exit 1
              shift
            else
              echo "runctl stray kill: not a directory: $1" >&2
              exit 1
            fi
            ;;
        esac
      done
      [[ -n "$proj" ]] || proj="$(pwd)"
      # shellcheck source=../lib/run-lib.sh
      source "$RUNCTL_PKG_ROOT/lib/run-lib.sh"
      run_project_init "$proj"
      RUN_STRAY_DRY_RUN="$dry" run_with_lock run_project_stray_kill
      local n="${RUN_LAST_STRAY_KILL_COUNT:-0}"
      if [[ "$dry" == "1" ]]; then
        echo "runctl stray kill: dry-run complete ($n pid(s) would be killed)"
      else
        echo "runctl stray kill: done ($n pid(s) signaled)"
      fi
      ;;
    "")
      cmd_stray_kill_usage
      exit 1
      ;;
    *)
      echo "runctl stray: unknown subcommand: $sub (try: stray kill)" >&2
      exit 1
      ;;
  esac
}

cmd_reconcile() {
  local proj=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h | --help)
        cat <<EOF
${_b}runctl reconcile${_r} — refresh ${_d}.run${_r} state from a live listener

${_y}Usage:${_r}  runctl reconcile [dir]

Reads ${_c}.run/ports.env${_r} (${_d}PORT${_r}, ${_d}RUN_DEV_SERVICE${_r}), finds the PID listening on that TCP port,
checks cwd is this project, then writes ${_d}.run/pids/<service>.pid${_r} and updates the user port registry.
Requires ${_c}lsof${_r}.
EOF
        exit 0
        ;;
      -*)
        echo "runctl reconcile: unknown option: $1" >&2
        exit 1
        ;;
      *)
        if [[ -d "$1" ]]; then
          proj="$(cd "$1" && pwd)" || exit 1
          shift
        else
          echo "runctl reconcile: not a directory: $1" >&2
          exit 1
        fi
        ;;
    esac
  done
  [[ -n "$proj" ]] || proj="$(pwd)"
  # shellcheck source=../lib/run-lib.sh
  source "$RUNCTL_PKG_ROOT/lib/run-lib.sh"
  run_project_init "$proj"
  run_with_lock run_project_reconcile_pidfiles
}

cmd_env() {
  local sub="${1:-}"
  shift || true
  case "$sub" in
    expand)
      command -v node >/dev/null 2>&1 || {
        echo "runctl: Node.js >= 18 is required for env expand." >&2
        exit 1
      }
      exec node "$RUNCTL_PKG_ROOT/scripts/expand-env-manifest.mjs" "$@"
      ;;
    *)
      echo "runctl env: unknown subcommand: ${sub:-<none>} (try: env expand)" >&2
      exit 1
      ;;
  esac
}

cmd_update_usage() {
  cat <<EOF
${_b}runctl update${_r} — refresh the global CLI (pnpm/npm global install)

${_y}Usage:${_r}  runctl update [npm|git|auto] [options]

${_y}Source${_r} ${_d}(pick one; default when omitted: ${_c}auto${_r})${_r}
  ${_c}npm${_r} | ${_c}--registry${_r}   Latest from npm only (${_d}${RUNCTL_PACKAGE:-@zendero/runctl}@latest${_r})
  ${_c}git${_r} | ${_c}--git${_r}         From Git only (${_d}RUNCTL_GIT_BASE + ref${_r})
  ${_c}auto${_r} | ${_c}--auto${_r}      Try npm @latest, then Git if that fails

${_y}Options${_r}
  ${_c}--pm${_r} ${_d}pnpm|npm${_r}     Package manager ${_d}(default: pnpm if on PATH, else npm)${_r}
  ${_c}--ref${_r} ${_d}<ref>${_r}      Git ref for --git / Git fallback ${_d}(default: RUNCTL_GIT_REF or main)${_r}
  ${_c}-h${_r}, ${_c}--help${_r}              This help

${_y}Environment${_r} ${_d}(optional; same as install-global.sh)${_r}
  RUNCTL_PACKAGE   npm name ${_d}(default: @zendero/runctl)${_r}
  RUNCTL_GIT_BASE  Git URL without fragment ${_d}(default: git+https://github.com/DoctorKhan/runctl.git)${_r}
  RUNCTL_GIT_REF   default Git ref ${_d}(default: main)${_r}
  RUNCTL_PNPM_VERSION  Force pnpm version for npm-exec fallback ${_d}(e.g. 10.33.0)${_r}
  RUNCTL_UPDATE_SKIP_PNPM_HINT  Set to ${_c}1${_r} to hide the post-update pnpm version hint ${_d}(CI also hides)${_r}

${_y}pnpm version / “pnpm self-update” does nothing${_r}
  pnpm often prints an upgrade banner or suggests ${_c}pnpm self-update${_r}. That advice targets the
  project ${_c}packageManager${_r} pin; ${_c}pnpm add -g${_r} uses a ${_b}different${_r} default pnpm
  (e.g. Volta’s global toolchain). So self-update may say you are already on 10.33.0 while the footer
  still shows 10.27.0 — both can be “true.” Fix the ${_b}global${_r} default, not self-update alone:

  ${_c}volta install pnpm@<version>${_r}   ${_d}match your repo / Volta default${_r}
  ${_c}corepack enable && corepack prepare pnpm@<version> --activate${_r}
  ${_c}RUNCTL_PNPM_VERSION=<version> runctl update git${_r}
  ${_c}runctl update --pm npm${_r}   ${_d}use npm for this install instead${_r}

  A short hint is printed after a successful ${_c}runctl update${_r} with pnpm unless ${_c}CI${_r} is set
  or ${_c}RUNCTL_UPDATE_SKIP_PNPM_HINT=1${_r}.
EOF
}

cmd_update_pick_pm() {
  if [[ -n "$1" ]]; then
    case "$1" in
      pnpm | npm) ;;
      *)
        echo "runctl update: unsupported --pm: $1 (use pnpm or npm)" >&2
        return 1
        ;;
    esac
    if ! command -v "$1" >/dev/null 2>&1; then
      echo "runctl update: package manager not on PATH: $1" >&2
      return 1
    fi
    printf '%s' "$1"
    return 0
  fi
  if command -v pnpm >/dev/null 2>&1; then
    printf 'pnpm'
    return 0
  fi
  if command -v npm >/dev/null 2>&1; then
    printf 'npm'
    return 0
  fi
  echo "runctl update: pnpm or npm required on PATH." >&2
  return 1
}

cmd_update() {
  local MODE="" PM="" GIT_REF="${RUNCTL_GIT_REF:-main}"
  local PKG="${RUNCTL_PACKAGE:-@zendero/runctl}"
  local GIT_BASE="${RUNCTL_GIT_BASE:-git+https://github.com/DoctorKhan/runctl.git}"
  local -a POS=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --registry)
        MODE="registry"
        shift
        ;;
      --git)
        MODE="git"
        shift
        ;;
      --auto)
        MODE="auto"
        shift
        ;;
      --pm)
        [[ $# -ge 2 ]] || {
          echo "runctl update: --pm requires a value" >&2
          exit 1
        }
        PM="$2"
        shift 2
        ;;
      --ref)
        [[ $# -ge 2 ]] || {
          echo "runctl update: --ref requires a value" >&2
          exit 1
        }
        GIT_REF="$2"
        shift 2
        ;;
      -h | --help)
        cmd_update_usage
        exit 0
        ;;
      -*)
        echo "runctl update: unknown option: $1" >&2
        cmd_update_usage >&2
        exit 1
        ;;
      *)
        POS+=("$1")
        shift
        ;;
    esac
  done

  local POS_MODE=""
  if [[ ${#POS[@]} -gt 1 ]]; then
    echo "runctl update: too many arguments (${POS[*]}). Use at most one of: npm, git, auto" >&2
    exit 1
  fi
  if [[ ${#POS[@]} -eq 1 ]]; then
    case "${POS[0]}" in
      npm)
        POS_MODE="registry"
        ;;
      git)
        POS_MODE="git"
        ;;
      auto)
        POS_MODE="auto"
        ;;
      *)
        echo "runctl update: unknown argument: ${POS[0]} (expected: npm, git, auto — runctl update --help)" >&2
        exit 1
        ;;
    esac
  fi
  if [[ -n "$MODE" && -n "$POS_MODE" && "$MODE" != "$POS_MODE" ]]; then
    echo "runctl update: conflicting source (npm/git/auto vs --registry/--git/--auto)" >&2
    exit 1
  fi
  if [[ -n "$POS_MODE" ]]; then
    MODE="$POS_MODE"
  fi
  [[ -n "$MODE" ]] || MODE="auto"

  local pm git_target ver_now
  pm="$(cmd_update_pick_pm "$PM")" || exit 1
  git_target="${GIT_BASE}#${GIT_REF}"
  ver_now="$(_runctl_pkg_version)"

  _remove_conflicting_global_runctl() {
    # A legacy package named "runctl" can own the same binary name and shadow @zendero/runctl.
    # Best-effort remove before reinstalling the intended package.
    if [[ "$PKG" != "@zendero/runctl" ]]; then
      return 0
    fi
    if [[ "$pm" == "pnpm" ]]; then
      _runctl_pnpm_exec remove -g runctl >/dev/null 2>&1 || true
    else
      npm uninstall -g runctl >/dev/null 2>&1 || true
    fi
  }

  _git_base_for_ls_remote() {
    local base="$1"
    printf '%s' "${base#git+}"
  }

  _resolve_git_ref_sha() {
    local base_url="$1"
    local ref="$2"
    local remote sha
    remote="$(_git_base_for_ls_remote "$base_url")"
    command -v git >/dev/null 2>&1 || return 1
    sha="$(git ls-remote "$remote" "$ref" 2>/dev/null | awk 'NR==1{print $1}')"
    [[ "$sha" =~ ^[0-9a-fA-F]{40}$ ]] || return 1
    printf '%s' "$sha"
  }

  _update_registry() {
    local spec="${PKG}@latest"
    printf '%s\n' "${_c}▶${_r} ${_b}runctl update${_r} ${_d}·${_r} ${_c}v${ver_now}${_r} ${_d}·${_r} registry ${_g}${spec}${_r}" >&2
    _remove_conflicting_global_runctl
    if [[ "$pm" == "pnpm" ]]; then
      _runctl_pnpm_exec add -g --force --loglevel error "$spec"
    else
      npm install -g --force --silent --no-fund --no-audit "$spec"
    fi
  }

  _update_git() {
    local sha spec
    if sha="$(_resolve_git_ref_sha "$GIT_BASE" "$GIT_REF")"; then
      spec="${GIT_BASE}#${sha}"
      printf '%s\n' "${_c}▶${_r} ${_b}runctl update${_r} ${_d}·${_r} ${_c}v${ver_now}${_r} ${_d}·${_r} git ${_g}${GIT_REF}${_r} ${_d}@${sha:0:12}${_r}" >&2
    else
      spec="$git_target"
      printf '%s\n' "${_c}▶${_r} ${_b}runctl update${_r} ${_d}·${_r} ${_c}v${ver_now}${_r} ${_d}·${_r} git ${_g}${git_target}${_r}" >&2
      echo "runctl update: could not resolve ref to SHA; proceeding with ref directly." >&2
    fi
    _remove_conflicting_global_runctl
    if [[ "$pm" == "pnpm" ]]; then
      _runctl_pnpm_exec add -g --force --loglevel error "$spec"
    else
      npm install -g --force --silent --no-fund --no-audit "$spec"
    fi
  }

  case "$MODE" in
    registry)
      _update_registry
      ;;
    git)
      _update_git
      ;;
    auto)
      if ! _update_registry; then
        echo "runctl update: registry install failed; trying Git..." >&2
        _update_git
      fi
      ;;
    *)
      echo "runctl update: internal error: unknown mode $MODE" >&2
      exit 1
      ;;
  esac

  local ver_installed
  ver_installed="$(_runctl_pkg_version)"
  printf '%s\n' "${_g}✓${_r} ${_b}runctl${_r} ${_c}v${ver_installed}${_r} ${_d}· global install refreshed${_r}" >&2

  _runctl_maybe_print_pnpm_update_hint "$pm"
}

cmd_doctor() {
  local proj
  proj="$(pwd)"
  [[ $# -ge 1 && -d "$1" ]] && proj="$(cd "$1" && pwd)"
  echo "runctl doctor"
  local ec=0
  if command -v node >/dev/null 2>&1 && node -e 'process.exit(parseInt(process.versions.node,10)>=18?0:1)' 2>/dev/null; then
    printf '  %-12s %s\n' "node:" "$(node -v) (ok)"
  else
    printf '  %-12s %s\n' "node:" "missing or < 18 (required)" >&2
    ec=1
  fi
  if command -v lsof >/dev/null 2>&1; then
    printf '  %-12s %s\n' "lsof:" "present (port detection / gc)"
  else
    printf '  %-12s %s\n' "lsof:" "missing — install for free-port + ports gc" >&2
  fi
  local pm=""
  if command -v pnpm >/dev/null 2>&1; then pm="pnpm $(pnpm -v 2>/dev/null || echo '')"
  elif command -v npm >/dev/null 2>&1; then pm="npm $(npm -v 2>/dev/null || echo '')"
  elif command -v bun >/dev/null 2>&1; then pm="bun $(bun -v 2>/dev/null || echo '')"
  elif command -v yarn >/dev/null 2>&1; then pm="yarn $(yarn -v 2>/dev/null || echo '')"
  else
    pm="none found"
    ec=1
  fi
  printf '  %-12s %s\n' "package mgr:" "$pm"
  if [[ -f "$proj/package.json" ]]; then
    printf '  %-12s %s\n' "package.json:" "$proj (ok)"
  else
    printf '  %-12s %s\n' "package.json:" "not found in $proj" >&2
    ec=1
  fi
  printf '  %-12s %s\n' "child env:" "PORT and HOST are set for package scripts; custom Node servers should listen on process.env.PORT (and bind HOST if needed)."
  return "$ec"
}

cmd_logs() {
  local proj lines="${RUNCTL_LOG_LINES:-80}"
  proj="$(pwd)"
  local -a pos=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -n | --lines)
        lines="${2:-80}"
        shift 2
        ;;
      -h | --help)
        echo "Usage: runctl logs [dir] [service]" >&2
        echo "       Default service: RUNCTL_SERVICE, else package.json name, else web." >&2
        echo "       runctl logs [--lines N]" >&2
        exit 0
        ;;
      *)
        pos+=("$1")
        shift
        ;;
    esac
  done
  if [[ ${#pos[@]} -ge 1 && -d "${pos[0]}" ]]; then
    proj="$(cd "${pos[0]}" && pwd)"
    pos=("${pos[@]:1}")
  fi
  local svc="${pos[0]:-}"
  # shellcheck source=../lib/run-lib.sh
  source "$RUNCTL_PKG_ROOT/lib/run-lib.sh"
  run_project_init "$proj"
  if [[ -z "$svc" ]]; then
    svc="$(run_default_service_name)"
  fi
  local logf="$RUN_LOCAL_STATE/logs/${svc}.log"
  if [[ ! -f "$logf" ]]; then
    echo "runctl logs: no file at $logf" >&2
    if [[ -d "$RUN_LOCAL_STATE/logs" ]]; then
      echo "Available logs:" >&2
      ls -1 "$RUN_LOCAL_STATE/logs" 2>/dev/null | sed 's/^/  /' >&2 || true
    fi
    exit 1
  fi
  echo "runctl logs: $logf (last $lines lines)"
  tail -n "$lines" "$logf"
}

_runctl_pm() {
  printf '%s' "${PM:-pnpm}"
}

cmd_install() {
  local root="${RUNCTL_PROJECT_ROOT:-$PWD}"
  if [[ "$(_runctl_pm)" == "pnpm" ]]; then
    if command -v pnpm >/dev/null 2>&1; then
      (cd "$root" && exec pnpm install "$@")
    elif command -v npm >/dev/null 2>&1; then
      echo "runctl install: pnpm not found; using npm" >&2
      (cd "$root" && exec npm install "$@")
    else
      echo "runctl install: install pnpm (preferred) or npm" >&2
      exit 1
    fi
  else
    local pm="$(_runctl_pm)"
    command -v "$pm" >/dev/null 2>&1 || {
      echo "runctl install: $pm not on PATH" >&2
      exit 1
    }
    (cd "$root" && exec "$pm" install "$@")
  fi
}

cmd_run() {
  local root="${RUNCTL_PROJECT_ROOT:-$PWD}"
  local pm="$(_runctl_pm)"
  command -v "$pm" >/dev/null 2>&1 || {
    echo "runctl run: $pm not on PATH (set PM=…)" >&2
    exit 1
  }
  (cd "$root" && exec "$pm" run "$@")
}

cmd_exec() {
  local root="${RUNCTL_PROJECT_ROOT:-$PWD}"
  local pm="$(_runctl_pm)"
  command -v "$pm" >/dev/null 2>&1 || {
    echo "runctl exec: $pm not on PATH (set PM=…)" >&2
    exit 1
  }
  (cd "$root" && exec "$pm" exec "$@")
}

cmd_test() {
  local root="${RUNCTL_PROJECT_ROOT:-$PWD}"
  local pm="$(_runctl_pm)"
  command -v "$pm" >/dev/null 2>&1 || {
    echo "runctl test: $pm not on PATH (set PM=…)" >&2
    exit 1
  }
  (cd "$root" && exec "$pm" test "$@")
}

cmd_run_sh_usage() {
  cat <<EOF
${_b}runctl run-sh${_r} — emit the canonical example ${_c}run.sh${_r} (thin wrapper → runctl)

${_y}Usage:${_r}
  runctl run-sh [--print]
  runctl run-sh --write [--force] [-C dir]

${_y}Description${_r}
  Reads ${_c}examples/run.sh.example${_r} from this package (falls back to ${_c}run.sh${_r}).

  ${_c}--print${_r} ${_d}(default)${_r} prints to stdout — redirect into your repo:
    ${_d}runctl run-sh > run.sh && chmod +x run.sh${_r}

  ${_c}--write${_r} writes ${_c}run.sh${_r} under the target directory (default: ${_c}\$PWD${_r} or ${_c}RUNCTL_PROJECT_ROOT${_r} when set).
    Refuses to overwrite an existing file unless ${_c}--force${_r}.

${_y}Options${_r}
  ${_c}--print${_r}              Print to stdout ${_d}(default when --write not used)${_r}
  ${_c}--write${_r} | ${_c}-w${_r}           Write ${_c}run.sh${_r} in the target directory
  ${_c}--force${_r} | ${_c}-f${_r}           Overwrite ${_c}run.sh${_r} if it already exists
  ${_c}-C${_r} ${_c}dir${_r} | ${_c}--dir${_r} ${_c}dir${_r}   Target directory (default: ${_c}RUNCTL_PROJECT_ROOT${_r} or cwd)
  ${_c}-h${_r} | ${_c}--help${_r}           Show this help
EOF
}

_runctl_run_sh_example_path() {
  local ex="$RUNCTL_PKG_ROOT/examples/run.sh.example"
  local fb="$RUNCTL_PKG_ROOT/run.sh"
  if [[ -f "$ex" && -r "$ex" ]]; then
    printf '%s' "$ex"
    return 0
  fi
  if [[ -f "$fb" && -r "$fb" ]]; then
    printf '%s' "$fb"
    return 0
  fi
  return 1
}

cmd_run_sh() {
  local action=print
  local force=0
  local target_dir=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --print)
        action=print
        shift
        ;;
      --write | -w)
        action=write
        shift
        ;;
      --force | -f)
        force=1
        shift
        ;;
      -C | --dir)
        if [[ $# -lt 2 ]]; then
          echo "runctl run-sh: $1 requires a directory" >&2
          exit 1
        fi
        target_dir="$(cd "$2" && pwd)" || exit 1
        shift 2
        ;;
      -h | --help)
        cmd_run_sh_usage
        return 0
        ;;
      -*)
        echo "runctl run-sh: unknown option: $1" >&2
        cmd_run_sh_usage >&2
        exit 1
        ;;
      *)
        echo "runctl run-sh: unexpected argument: $1" >&2
        cmd_run_sh_usage >&2
        exit 1
        ;;
    esac
  done

  if [[ -z "$target_dir" ]]; then
    if [[ -n "${RUNCTL_PROJECT_ROOT:-}" && -d "$RUNCTL_PROJECT_ROOT" ]]; then
      target_dir="$(cd "$RUNCTL_PROJECT_ROOT" && pwd)"
    else
      target_dir="$(pwd)"
    fi
  fi

  local path
  path="$(_runctl_run_sh_example_path)" || {
    echo "runctl run-sh: example not found under $RUNCTL_PKG_ROOT" >&2
    exit 1
  }

  if [[ "$action" == "write" ]]; then
    local out="$target_dir/run.sh"
    if [[ -e "$out" && "$force" -ne 1 ]]; then
      echo "runctl run-sh: $out already exists (use --force to overwrite)" >&2
      exit 1
    fi
    cat "$path" >"$out"
    chmod +x "$out"
    echo "runctl run-sh: wrote $out" >&2
    return 0
  fi

  cat "$path"
}

cmd_version_print() {
  local ver
  ver="$(_runctl_pkg_version)"
  if [[ -t 1 ]]; then
    printf '%s\n\n' "${_b}runctl${_r} ${_c}v${ver}${_r}"
  else
    printf 'runctl %s\n\n' "$ver"
  fi
  printf '%s\n' "${_d}Install:${_r}"
  printf '%s\n' "  $RUNCTL_PKG_ROOT"
}

main() {
  local cmd="${1:-help}"
  shift || true
  case "$cmd" in
    start | dev) cmd_start "$@" ;;
    open)     cmd_open "$@" ;;
    stop)     cmd_stop "$@" ;;
    status)   cmd_status "$@" ;;
    ps)       cmd_ps "$@" ;;
    reconcile) cmd_reconcile "$@" ;;
    stray)    cmd_stray "$@" ;;
    logs)     cmd_logs "$@" ;;
    ports)    cmd_ports "$@" ;;
    env)      cmd_env "$@" ;;
    doctor)   cmd_doctor "$@" ;;
    update)   cmd_update "$@" ;;
    install)  cmd_install "$@" ;;
    run)      cmd_run "$@" ;;
    exec)     cmd_exec "$@" ;;
    test)     cmd_test "$@" ;;
    run-sh)   cmd_run_sh "$@" ;;

    # Plumbing
    lib-path) printf '%s\n' "$RUNCTL_PKG_ROOT/lib/run-lib.sh" ;;
    version | -v | --version) cmd_version_print ;;
    help | -h | --help) usage ;;

    # Hidden backward-compat aliases
    start-dev) cmd_start "$@" ;;
    stop-dev)  cmd_stop "$@" ;;
    status-dev) cmd_status "$@" ;;
    list)      cmd_ports list ;;
    gc)        cmd_ports gc ;;
    expand-env) cmd_env expand "$@" ;;

    *)
      echo "runctl: unknown command: $cmd" >&2
      echo ""
      usage
      exit 1
      ;;
  esac
}

main "$@"
