#!/usr/bin/env bash
# Runctl — put this on PATH (pnpm/npm link or devDependency .bin).
RUNCTL_PKG_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")/.." && pwd)"

_b="" _d="" _r="" _c="" _y=""
if [[ -t 1 ]]; then
  _b=$'\033[1m' _d=$'\033[2m' _r=$'\033[0m'
  _c=$'\033[36m' _y=$'\033[33m'
fi

usage() {
  cat <<EOF
${_b}runctl${_r} — dev-server orchestrator & port manager

${_y}Usage:${_r}  runctl <command> [options]

${_y}Dev server${_r}
  ${_c}start-dev${_r} [dir] [args]    Start dev server (cwd or dir)
  ${_c}stop-dev${_r}  [dir]           Stop daemons & release ports
  ${_c}status-dev${_r} [dir]          Show running state

${_y}Ports${_r}
  ${_c}list${_r}                      Show user-wide ~/.run port registry
  ${_c}gc${_r}                        Clean up stale port claims

${_y}Environment${_r}
  ${_c}expand-env${_r} [args]         Generate .env.local from manifest

${_y}Plumbing${_r}
  ${_c}lib-path${_r}                  Print path to run-lib.sh ${_d}(source \$(runctl lib-path))${_r}
  ${_c}run${_r} [args]                Execute this package's run.sh
  ${_c}version${_r}                   Print install location

${_d}As a devDependency, add to package.json scripts:
  "dev": "runctl start-dev"
  "dev:web": "runctl start-dev ./apps/web web auto"${_r}
EOF
}

main() {
  local cmd="${1:-help}"
  shift || true
  case "$cmd" in
    lib-path)
      printf '%s\n' "$RUNCTL_PKG_ROOT/lib/run-lib.sh"
      ;;
    expand-env)
      command -v node >/dev/null 2>&1 || {
        echo "runctl: Node.js >= 18 is required for expand-env." >&2
        exit 1
      }
      exec node "$RUNCTL_PKG_ROOT/scripts/expand-env-manifest.mjs" "$@"
      ;;
    list | gc)
      # shellcheck source=../lib/run-lib.sh
      source "$RUNCTL_PKG_ROOT/lib/run-lib.sh"
      case "$cmd" in
        list) run_global_list_ports ;;
        gc) run_global_gc ;;
      esac
      ;;
    start-dev)
      local proj
      if [[ $# -ge 1 && -d "$1" ]]; then
        proj="$(cd "$1" && pwd)"
        shift
      else
        proj="$(pwd)"
      fi
      # shellcheck source=../lib/run-lib.sh
      source "$RUNCTL_PKG_ROOT/lib/run-lib.sh"
      run_project_init "$proj"
      run_with_lock run_start_package_dev "$@"
      ;;
    stop-dev)
      local proj
      if [[ $# -ge 1 && -d "$1" ]]; then
        proj="$(cd "$1" && pwd)"
        shift
      else
        proj="$(pwd)"
      fi
      # shellcheck source=../lib/run-lib.sh
      source "$RUNCTL_PKG_ROOT/lib/run-lib.sh"
      run_project_init "$proj"
      run_stop_all
      ;;
    status-dev)
      local proj
      if [[ $# -ge 1 && -d "$1" ]]; then
        proj="$(cd "$1" && pwd)"
        shift
      else
        proj="$(pwd)"
      fi
      # shellcheck source=../lib/run-lib.sh
      source "$RUNCTL_PKG_ROOT/lib/run-lib.sh"
      run_project_init "$proj"
      run_local_status
      ;;
    run)
      exec bash "$RUNCTL_PKG_ROOT/run.sh" "$@"
      ;;
    help | -h | --help)
      usage
      ;;
    version | -v)
      printf '%s\n' "runctl @ $RUNCTL_PKG_ROOT"
      ;;
    *)
      usage
      exit 1
      ;;
  esac
}

main "$@"
