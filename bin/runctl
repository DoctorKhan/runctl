#!/usr/bin/env bash
# Runctl CLI â€” installed via pnpm/npm (devDependency .bin or global).
set -euo pipefail
RUNCTL_PKG_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")/.." && pwd)"

_b="" _d="" _r="" _c="" _y="" _g=""
if [[ -t 1 ]]; then
  _b=$'\033[1m' _d=$'\033[2m' _r=$'\033[0m'
  _c=$'\033[36m' _y=$'\033[33m' _g=$'\033[32m'
fi

usage() {
  cat <<EOF
${_b}runctl${_r} â€” dev-server orchestrator & port manager

${_y}Usage:${_r}  runctl <command> [options]

${_y}Commands${_r}
  ${_c}start${_r} | ${_c}dev${_r} [dir] [--script name]  Start dev server ${_d}(alias: dev = start)${_r}
  ${_c}open${_r}  [dir]                   Open running dev server in browser
  ${_c}stop${_r}  [dir]                   Stop daemons & release ports
  ${_c}status${_r} [dir]                  Show running state
  ${_c}logs${_r} [dir] [service]         Tail .run/logs/<service>.log ${_d}(default service: web)${_r}
  ${_c}ports${_r}                         List user-wide port registry (~/.run)
  ${_c}ports gc${_r}                      Clean up stale port claims
  ${_c}env expand${_r} <manifest> [opts]  Generate .env.local from manifest
  ${_c}doctor${_r}                        Check Node, tooling, and project basics
  ${_c}update${_r} [npm|git|auto] [opts]  Update global runctl ${_d}(default: auto; see runctl update --help)${_r}

${_y}Options${_r}
  ${_c}--script${_r} <name>               Package script to run ${_d}(default: dev)${_r}
  ${_c}--help${_r}, ${_c}-h${_r}                     Show this help

${_d}Quick start â€” add to package.json:
  "dev": "runctl start --script dev:server",
  "dev:server": "next dev",
  "dev:stop": "runctl stop"${_r}
EOF
}

_resolve_proj() {
  if [[ $# -ge 1 && -d "$1" ]]; then
    (cd "$1" && pwd)
  else
    pwd
  fi
}

cmd_start() {
  local proj script="" args=()
  proj="$(pwd)"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --script) script="${2:-}"; shift 2 ;;
      --) shift; args+=("$@"); break ;;
      -h | --help) usage; exit 0 ;;
      -*)
        echo "runctl start: unknown flag: $1" >&2
        exit 1
        ;;
      *)
        if [[ -d "$1" ]]; then
          proj="$(cd "$1" && pwd)"
          shift
        else
          args+=("$1")
          shift
        fi
        ;;
    esac
  done

  [[ -n "$script" ]] && export RUNCTL_PM_RUN_SCRIPT="$script"

  # shellcheck source=../lib/run-lib.sh
  source "$RUNCTL_PKG_ROOT/lib/run-lib.sh"
  run_project_init "$proj"
  run_with_lock run_start_package_dev "${args[@]+"${args[@]}"}"
}

cmd_open() {
  local proj
  proj="$(_resolve_proj "$@")"
  # shellcheck source=../lib/run-lib.sh
  source "$RUNCTL_PKG_ROOT/lib/run-lib.sh"
  run_project_init "$proj"
  local ports_env="$proj/.run/ports.env"
  if [[ ! -f "$ports_env" ]]; then
    echo "runctl open: no running server found (.run/ports.env missing)" >&2
    echo "Start one first: runctl start" >&2
    exit 1
  fi
  if ! run_local_has_live_service; then
    echo "runctl open: no running server found (saved port is stale)" >&2
    echo "Start one first: runctl start" >&2
    exit 1
  fi
  local port="" host=""
  while IFS= read -r line; do
    case "$line" in
      PORT=*) port="${line#PORT=}" ;;
      HOST=*) host="${line#HOST=}" ;;
    esac
  done <"$ports_env"
  if [[ -z "$port" ]]; then
    echo "runctl open: PORT not found in $ports_env" >&2
    exit 1
  fi
  [[ -z "$host" || "$host" == "0.0.0.0" || "$host" == "127.0.0.1" ]] && host="localhost"
  local url="http://${host}:${port}"
  echo "runctl open: opening ${url}"
  if command -v open >/dev/null 2>&1; then
    open "$url"
  elif command -v xdg-open >/dev/null 2>&1; then
    xdg-open "$url"
  elif command -v wslview >/dev/null 2>&1; then
    wslview "$url"
  else
    echo "runctl open: no browser opener found (tried open, xdg-open, wslview)" >&2
    echo "Visit: $url" >&2
    exit 1
  fi
}

cmd_stop() {
  local proj
  proj="$(_resolve_proj "$@")"
  # shellcheck source=../lib/run-lib.sh
  source "$RUNCTL_PKG_ROOT/lib/run-lib.sh"
  run_project_init "$proj"
  run_stop_all
  echo "runctl stop: stopped local services and released claimed ports for $proj"
}

cmd_status() {
  local proj
  proj="$(_resolve_proj "$@")"
  # shellcheck source=../lib/run-lib.sh
  source "$RUNCTL_PKG_ROOT/lib/run-lib.sh"
  run_project_init "$proj"
  run_local_status
}

cmd_ports() {
  # shellcheck source=../lib/run-lib.sh
  source "$RUNCTL_PKG_ROOT/lib/run-lib.sh"
  local sub="${1:-list}"
  case "$sub" in
    list | "") run_global_list_ports ;;
    gc) run_global_gc ;;
    *)
      echo "runctl ports: unknown subcommand: $sub (try: ports, ports gc)" >&2
      exit 1
      ;;
  esac
}

cmd_env() {
  local sub="${1:-}"
  shift || true
  case "$sub" in
    expand)
      command -v node >/dev/null 2>&1 || {
        echo "runctl: Node.js >= 18 is required for env expand." >&2
        exit 1
      }
      exec node "$RUNCTL_PKG_ROOT/scripts/expand-env-manifest.mjs" "$@"
      ;;
    *)
      echo "runctl env: unknown subcommand: ${sub:-<none>} (try: env expand)" >&2
      exit 1
      ;;
  esac
}

cmd_update_usage() {
  cat <<EOF
${_b}runctl update${_r} â€” refresh the global CLI (pnpm/npm global install)

${_y}Usage:${_r}  runctl update [npm|git|auto] [options]

${_y}Source${_r} ${_d}(pick one; default when omitted: ${_c}auto${_r})${_r}
  ${_c}npm${_r} | ${_c}--registry${_r}   Latest from npm only (${_d}${RUNCTL_PACKAGE:-@zendero/runctl}@latest${_r})
  ${_c}git${_r} | ${_c}--git${_r}         From Git only (${_d}RUNCTL_GIT_BASE + ref${_r})
  ${_c}auto${_r} | ${_c}--auto${_r}      Try npm @latest, then Git if that fails

${_y}Options${_r}
  ${_c}--pm${_r} ${_d}pnpm|npm${_r}     Package manager ${_d}(default: pnpm if on PATH, else npm)${_r}
  ${_c}--ref${_r} ${_d}<ref>${_r}      Git ref for --git / Git fallback ${_d}(default: RUNCTL_GIT_REF or main)${_r}
  ${_c}-h${_r}, ${_c}--help${_r}              This help

${_y}Environment${_r} ${_d}(optional; same as install-global.sh)${_r}
  RUNCTL_PACKAGE   npm name ${_d}(default: @zendero/runctl)${_r}
  RUNCTL_GIT_BASE  Git URL without fragment ${_d}(default: git+https://github.com/DoctorKhan/runctl.git)${_r}
  RUNCTL_GIT_REF   default Git ref ${_d}(default: main)${_r}
EOF
}

cmd_update_pick_pm() {
  if [[ -n "$1" ]]; then
    case "$1" in
      pnpm | npm) ;;
      *)
        echo "runctl update: unsupported --pm: $1 (use pnpm or npm)" >&2
        return 1
        ;;
    esac
    if ! command -v "$1" >/dev/null 2>&1; then
      echo "runctl update: package manager not on PATH: $1" >&2
      return 1
    fi
    printf '%s' "$1"
    return 0
  fi
  if command -v pnpm >/dev/null 2>&1; then
    printf 'pnpm'
    return 0
  fi
  if command -v npm >/dev/null 2>&1; then
    printf 'npm'
    return 0
  fi
  echo "runctl update: pnpm or npm required on PATH." >&2
  return 1
}

cmd_update() {
  local MODE="" PM="" GIT_REF="${RUNCTL_GIT_REF:-main}"
  local PKG="${RUNCTL_PACKAGE:-@zendero/runctl}"
  local GIT_BASE="${RUNCTL_GIT_BASE:-git+https://github.com/DoctorKhan/runctl.git}"
  local -a POS=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --registry)
        MODE="registry"
        shift
        ;;
      --git)
        MODE="git"
        shift
        ;;
      --auto)
        MODE="auto"
        shift
        ;;
      --pm)
        [[ $# -ge 2 ]] || {
          echo "runctl update: --pm requires a value" >&2
          exit 1
        }
        PM="$2"
        shift 2
        ;;
      --ref)
        [[ $# -ge 2 ]] || {
          echo "runctl update: --ref requires a value" >&2
          exit 1
        }
        GIT_REF="$2"
        shift 2
        ;;
      -h | --help)
        cmd_update_usage
        exit 0
        ;;
      -*)
        echo "runctl update: unknown option: $1" >&2
        cmd_update_usage >&2
        exit 1
        ;;
      *)
        POS+=("$1")
        shift
        ;;
    esac
  done

  local POS_MODE=""
  if [[ ${#POS[@]} -gt 1 ]]; then
    echo "runctl update: too many arguments (${POS[*]}). Use at most one of: npm, git, auto" >&2
    exit 1
  fi
  if [[ ${#POS[@]} -eq 1 ]]; then
    case "${POS[0]}" in
      npm)
        POS_MODE="registry"
        ;;
      git)
        POS_MODE="git"
        ;;
      auto)
        POS_MODE="auto"
        ;;
      *)
        echo "runctl update: unknown argument: ${POS[0]} (expected: npm, git, auto â€” runctl update --help)" >&2
        exit 1
        ;;
    esac
  fi
  if [[ -n "$MODE" && -n "$POS_MODE" && "$MODE" != "$POS_MODE" ]]; then
    echo "runctl update: conflicting source (npm/git/auto vs --registry/--git/--auto)" >&2
    exit 1
  fi
  if [[ -n "$POS_MODE" ]]; then
    MODE="$POS_MODE"
  fi
  [[ -n "$MODE" ]] || MODE="auto"

  local pm git_target
  pm="$(cmd_update_pick_pm "$PM")" || exit 1
  git_target="${GIT_BASE}#${GIT_REF}"

  _update_registry() {
    local spec="${PKG}@latest"
    echo "runctl update: installing latest from registry ($spec)..."
    if [[ "$pm" == "pnpm" ]]; then
      pnpm add -g "$spec"
    else
      npm install -g "$spec"
    fi
  }

  _update_git() {
    echo "runctl update: installing from Git ($git_target)..."
    if [[ "$pm" == "pnpm" ]]; then
      pnpm add -g "$git_target"
    else
      npm install -g "$git_target"
    fi
  }

  case "$MODE" in
    registry)
      _update_registry
      ;;
    git)
      _update_git
      ;;
    auto)
      if _update_registry; then
        return 0
      fi
      echo "runctl update: registry install failed; trying Git..." >&2
      _update_git
      ;;
    *)
      echo "runctl update: internal error: unknown mode $MODE" >&2
      exit 1
      ;;
  esac
}

cmd_doctor() {
  local proj
  proj="$(pwd)"
  [[ $# -ge 1 && -d "$1" ]] && proj="$(cd "$1" && pwd)"
  echo "runctl doctor"
  local ec=0
  if command -v node >/dev/null 2>&1 && node -e 'process.exit(parseInt(process.versions.node,10)>=18?0:1)' 2>/dev/null; then
    printf '  %-12s %s\n' "node:" "$(node -v) (ok)"
  else
    printf '  %-12s %s\n' "node:" "missing or < 18 (required)" >&2
    ec=1
  fi
  if command -v lsof >/dev/null 2>&1; then
    printf '  %-12s %s\n' "lsof:" "present (port detection / gc)"
  else
    printf '  %-12s %s\n' "lsof:" "missing â€” install for free-port + ports gc" >&2
  fi
  local pm=""
  if command -v pnpm >/dev/null 2>&1; then pm="pnpm $(pnpm -v 2>/dev/null || echo '')"
  elif command -v npm >/dev/null 2>&1; then pm="npm $(npm -v 2>/dev/null || echo '')"
  elif command -v bun >/dev/null 2>&1; then pm="bun $(bun -v 2>/dev/null || echo '')"
  elif command -v yarn >/dev/null 2>&1; then pm="yarn $(yarn -v 2>/dev/null || echo '')"
  else
    pm="none found"
    ec=1
  fi
  printf '  %-12s %s\n' "package mgr:" "$pm"
  if [[ -f "$proj/package.json" ]]; then
    printf '  %-12s %s\n' "package.json:" "$proj (ok)"
  else
    printf '  %-12s %s\n' "package.json:" "not found in $proj" >&2
    ec=1
  fi
  return "$ec"
}

cmd_logs() {
  local proj lines="${RUNCTL_LOG_LINES:-80}"
  proj="$(pwd)"
  local -a pos=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -n | --lines)
        lines="${2:-80}"
        shift 2
        ;;
      -h | --help)
        echo "Usage: runctl logs [dir] [service]  (default service: web)" >&2
        echo "       runctl logs [--lines N]" >&2
        exit 0
        ;;
      *)
        pos+=("$1")
        shift
        ;;
    esac
  done
  if [[ ${#pos[@]} -ge 1 && -d "${pos[0]}" ]]; then
    proj="$(cd "${pos[0]}" && pwd)"
    pos=("${pos[@]:1}")
  fi
  local svc="${pos[0]:-web}"
  # shellcheck source=../lib/run-lib.sh
  source "$RUNCTL_PKG_ROOT/lib/run-lib.sh"
  run_project_init "$proj"
  local logf="$RUN_LOCAL_STATE/logs/${svc}.log"
  if [[ ! -f "$logf" ]]; then
    echo "runctl logs: no file at $logf" >&2
    if [[ -d "$RUN_LOCAL_STATE/logs" ]]; then
      echo "Available logs:" >&2
      ls -1 "$RUN_LOCAL_STATE/logs" 2>/dev/null | sed 's/^/  /' >&2 || true
    fi
    exit 1
  fi
  echo "runctl logs: $logf (last $lines lines)"
  tail -n "$lines" "$logf"
}

cmd_version_print() {
  local ver="?"
  if command -v node >/dev/null 2>&1; then
    ver="$(
      node -e 'const fs=require("fs"); console.log(JSON.parse(fs.readFileSync(process.argv[1],"utf8")).version);' \
        "$RUNCTL_PKG_ROOT/package.json" 2>/dev/null || echo "?"
    )"
  fi
  printf '%s\n' "runctl $ver â€” $RUNCTL_PKG_ROOT"
}

main() {
  local cmd="${1:-help}"
  shift || true
  case "$cmd" in
    start | dev) cmd_start "$@" ;;
    open)     cmd_open "$@" ;;
    stop)     cmd_stop "$@" ;;
    status)   cmd_status "$@" ;;
    logs)     cmd_logs "$@" ;;
    ports)    cmd_ports "$@" ;;
    env)      cmd_env "$@" ;;
    doctor)   cmd_doctor "$@" ;;
    update)   cmd_update "$@" ;;

    # Plumbing
    lib-path) printf '%s\n' "$RUNCTL_PKG_ROOT/lib/run-lib.sh" ;;
    version | -v) cmd_version_print ;;
    help | -h | --help) usage ;;

    # Hidden backward-compat aliases
    start-dev) cmd_start "$@" ;;
    stop-dev)  cmd_stop "$@" ;;
    status-dev) cmd_status "$@" ;;
    list)      cmd_ports list ;;
    gc)        cmd_ports gc ;;
    expand-env) cmd_env expand "$@" ;;

    *)
      echo "runctl: unknown command: $cmd" >&2
      echo ""
      usage
      exit 1
      ;;
  esac
}

main "$@"
