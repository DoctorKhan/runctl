#!/usr/bin/env bash
# Single entrypoint for the Runner install — put this on PATH (see README).
RUNNER_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")/.." && pwd)"

usage() {
  cat <<EOF
Runner (install: $RUNNER_ROOT)

  runner lib-path              Print path to run-lib.sh (for: source PATH_FROM_LIB_PATH)
  runner expand-env ...        Env manifest → .env.local (same args as the .mjs script)
  runner list | gc             User-wide ~/.run port registry
  runner run ...               This package’s run.sh (list, gc, status, …)
  runner version               Show install root

Other repos: install Runner once on PATH; keep only a small ./run.sh that runs:
  source "\$(runner lib-path)"
(or set RUNNER_HOME / RUN_LIB — see README.)
EOF
}

main() {
  local cmd="${1:-help}"
  shift || true
  case "$cmd" in
    lib-path)
      printf '%s\n' "$RUNNER_ROOT/lib/run-lib.sh"
      ;;
    expand-env)
      exec node "$RUNNER_ROOT/scripts/expand-env-manifest.mjs" "$@"
      ;;
    list | gc)
      # shellcheck source=../lib/run-lib.sh
      source "$RUNNER_ROOT/lib/run-lib.sh"
      case "$cmd" in
        list) run_global_list_ports ;;
        gc) run_global_gc ;;
      esac
      ;;
    run)
      exec bash "$RUNNER_ROOT/run.sh" "$@"
      ;;
    help | -h | --help)
      usage
      ;;
    version | -v)
      printf '%s\n' "runner @ $RUNNER_ROOT"
      ;;
    *)
      usage
      exit 1
      ;;
  esac
}

main "$@"
